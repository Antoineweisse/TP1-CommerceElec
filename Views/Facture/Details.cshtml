@model tp1.Models.Facture
@{
    ViewData["Title"] = "Facture #" + Model.Id;
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header d-flex justify-content-between">
            <h3 class="mb-0">Facture #@Model.Id</h3>
            <span>@Model.DateFacture.ToString("dd MMMM yyyy à HH:mm")</span>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Client :</strong> @Model.Client.Prenom @Model.Client.Nom<br />
                    <strong>Email :</strong> @Model.Client.Email
                </div>
                <div class="col-md-6 text-end">
                    <strong>Paiement Id :</strong> @Model.PaiementId
                </div>
            </div>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Produit</th>
                        <th>Vendeur</th>
                        <th class="text-center">Quantité</th>
                        <th class="text-end">Prix unitaire</th>
                        <th class="text-end">Sous-total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ligne in Model.Commande.Lignes)
                    {
                        <tr>
                            <td>@ligne.Produit.Titre</td>
                            <td>@ligne.Produit.Vendeur?.Prenom @ligne.Produit.Vendeur?.Nom</td>
                            <td class="text-center">@ligne.Quantite</td>
                            <td class="text-end">@ligne.PrixUnitaire.ToString("C")</td>
                            <td class="text-end">@((ligne.PrixUnitaire * ligne.Quantite).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="4" class="text-end">Total</td>
                        <td class="text-end">@Model.MontantTotal.ToString("C")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="MesAchats" class="btn btn-secondary">Retour à mes achats</a>
    </div>
</div>
