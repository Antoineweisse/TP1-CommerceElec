@model List<tp1.Models.LigneCommande>
@{
    ViewData["Title"] = "Mes ventes";
}

<div class="container mt-4">
    <h2>Mes ventes</h2>

    <div class="alert alert-success">
        <strong>Total gagné :</strong> @(((decimal)ViewBag.TotalGagne).ToString("C"))
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">Aucune vente pour le moment.</div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Produit</th>
                    <th>Client</th>
                    <th class="text-center">Quantité</th>
                    <th class="text-end">Prix unitaire</th>
                    <th class="text-end">Sous-total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ligne in Model)
                {
                    <tr>
                        <td>@ligne.Commande.Date.ToString("dd/MM/yyyy")</td>
                        <td>@ligne.Produit.Titre</td>
                        <td>@ligne.Commande.Utilisateur.Prenom @ligne.Commande.Utilisateur.Nom</td>
                        <td class="text-center">@ligne.Quantite</td>
                        <td class="text-end">@ligne.PrixUnitaire.ToString("C")</td>
                        <td class="text-end fw-bold">@((ligne.PrixUnitaire * ligne.Quantite).ToString("C"))</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Retour à l'accueil</a>
</div>
