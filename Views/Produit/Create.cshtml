@model tp1.Models.Produit

@{
    ViewData["Title"] = "Vente article";
}

<div class="container mt-4">
    <h2>Mettre un article en vente</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div class="mb-3">
                    <label asp-for="Titre" class="form-label"></label>
                    <input asp-for="Titre" class="form-control" placeholder="Ex: Laptop Dell XPS" />
                    <span asp-validation-for="Titre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Prix" class="form-label"></label>
                    <input asp-for="Prix" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Prix" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label">URL de l'image</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                </div>

                <div class="mb-3">
                    <label asp-for="Categorie" class="form-label">Catégorie</label>
                    <input asp-for="Categorie" class="form-control" placeholder="Ex: Électronique, Sport, Maison..." />
                    <span asp-validation-for="Categorie" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Publier l'annonce</button>
                <a asp-action="MesProduits" class="btn btn-secondary">Annuler</a>
            </form>
        </div>
    </div>
</div>