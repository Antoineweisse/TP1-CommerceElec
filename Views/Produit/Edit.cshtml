@model tp1.Models.Produit

@{
    ViewData["Title"] = "Modifier mon article";
}

<div class="container mt-4">
    <h2>Modifier mon article</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Titre" class="form-label font-weight-bold"></label>
                    <input asp-for="Titre" class="form-control" />
                    <span asp-validation-for="Titre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Prix" class="form-label"></label>
                    <input asp-for="Prix" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Prix" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Categorie" class="form-label"></label>
                    <input asp-for="Categorie" class="form-control" />
                    <span asp-validation-for="Categorie" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label">URL de l'image</label>
                    <input asp-for="ImageUrl" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
                    <a asp-action="MesProduits" class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
        
        <div class="col-md-4 offset-md-1 text-center">
            <p class="text-muted">Aperçu actuel :</p>
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="Aperçu" style="max-height: 300px;" />
        </div>
    </div>
</div>