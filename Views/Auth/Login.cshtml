@{
    ViewData["Title"] = "Connexion";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Connexion</h3>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center">
                            @ViewBag.Error
                        </div>
                    }

                    <form method="post" asp-action="Login">
                        <div class="form-group mb-3">
                            <label for="email" class="form-label">Adresse courriel</label>
                            <input name="email" id="email" type="email" placeholder="nom@exemple.com" class="form-control" required />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="motDePasse" class="form-label">Mot de passe</label>
                            <input name="motDePasse" id="motDePasse" type="password" placeholder="********" class="form-control" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-block">Se connecter</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center text-muted">
                    Pas encore de compte ? <a asp-action="Register">S'inscrire</a>
                </div>
            </div>
        </div>
    </div>
</div>