@{
    ViewData["Title"] = "Paiement échoué";
}

<div class="container mt-5 text-center">
    <div class="alert alert-danger">
        <h2>Paiement échoué</h2>
        <p>@(TempData["ErrorMessage"] ?? "Une erreur est survenue lors du traitement de votre paiement.")</p>
    </div>
    <a asp-controller="Payment" asp-action="Index" class="btn btn-warning">Réessayer</a>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Retour à l'accueil</a>
</div>