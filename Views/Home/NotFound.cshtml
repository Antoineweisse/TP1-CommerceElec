@{
    ViewData["Title"] = "Page introuvable";
}

<div class="container text-center mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="display-1 fw-bold text-primary">404</h1>
            <h2 class="mb-4">Oups ! La page que vous cherchez n'existe plus.</h2>
            <p class="text-muted mb-5">
                Il semble que le produit ou la page que vous essayez d'atteindre ait été déplacé ou supprimé.
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5">
                Retour à la boutique
            </a>
        </div>
    </div>
</div>