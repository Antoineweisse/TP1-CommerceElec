@model IEnumerable<tp1.Models.Produit>

@{
    ViewData["Title"] = "Accueil - Boutique";
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-4">
            <h1 class="display-5 mb-0">Nos Produits</h1>
        </div>

        <div class="col-md-5">
            <form asp-action="Index" method="get" class="d-flex">
                <input type="hidden" name="category" value="@Context.Request.Query["category"]" />
                <input class="form-control me-2" type="search" placeholder="Rechercher..." name="search" value="@Context.Request.Query["search"]">
                <button class="btn btn-outline-primary" type="submit">Rechercher</button>
            </form>
        </div>

        <div class="col-md-3 text-end">
            <a asp-controller="Panier" asp-action="Index" class="btn btn-outline-secondary position-relative">
                Mon Panier
            </a>
            <a class="btn btn-primary-outline" asp-controller="Auth" asp-action="Profil">
                Mon Compte
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="btn-group" role="group" aria-label="Filtres">
                <a 
                    asp-action="Index" 
                    asp-route-search="@Context.Request.Query["search"]"
                    class="btn btn-outline-secondary @(string.IsNullOrEmpty(Context.Request.Query["category"]) ? "active" : "")"
                >
                    Tous
                </a>
                @if (ViewBag.Categories != null){
                    foreach (dynamic cat in ViewBag.Categories)
                    {
                        <a 
                            asp-action="Index" 
                            asp-route-search="@Context.Request.Query["search"]"
                            asp-route-category="@cat" 
                            class="btn btn-outline-secondary @(Context.Request.Query["category"] == cat ? "active" : "")"
                            >
                                @cat
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @if (!Model.Any())
        {
            <div class="col">
                <div class="alert alert-info" role="alert">
                    Aucun produit trouvé.
                </div>
            </div>
        }

        @foreach (Produit produit in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@produit.ImageUrl" class="card-img-top p-3" alt="..." style="height: 200px; object-fit: contain;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate">@produit.Titre</h5>
                        <p class="card-text text-muted text-truncate">@produit.Description</p>
                        <p class="card-text fw-bold mt-auto">$@produit.Prix.ToString("F2")</p>
                        <p class="card-text fw-bold mt-auto">$@produit.Categorie</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Details" asp-route-id="@produit.Id" class="btn btn-sm btn-outline-primary">
                                Voir
                            </a>
                            <form asp-controller="Panier" asp-action="Ajouter" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@produit.Id" />
                                <input type="hidden" name="quantite" value="1" />
                                <button type="submit" class="btn btn-sm btn-success">
                                   Ajouter
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>