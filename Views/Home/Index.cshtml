@model IEnumerable<tp1.Models.Produit>

@{
    ViewData["Title"] = "Accueil - Boutique";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">Nos Produits</h1>
        </div>
        <div class="col-md-4">
            <form method="get" class="d-flex">
                <input class="form-control me-2" type="search" placeholder="Rechercher un produit..." aria-label="Search" name="search">
                <button class="btn btn-outline-primary" type="submit">Rechercher</button>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="btn-group" role="group" aria-label="Filtres">
                <a href="#" class="btn btn-outline-secondary">Tous</a>
                <a href="#" class="btn btn-outline-secondary">Électronique</a>
                <a href="#" class="btn btn-outline-secondary">Vêtements</a>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var produit in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@produit.ImageUrl" class="card-img-top p-3" alt="..." style="height: 200px; object-fit: contain;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate">@produit.Titre</h5>
                        <p class="card-text text-muted text-truncate">@produit.Description</p>
                        <p class="card-text fw-bold mt-auto">$@produit.Prix.ToString("F2")</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <a href="#" class="btn btn-sm btn-outline-primary">Voir</a>
                            <a href="#" class="btn btn-sm btn-success">Ajouter</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>