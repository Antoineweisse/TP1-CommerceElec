@model tp1.Models.Produit

@{
    ViewData["Title"] = Model.Titre;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item active">@Model.Categorie</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-6 text-center">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.Titre" style="max-height: 500px; object-fit: contain;">
        </div>

        <div class="col-md-6">
            <h1 class="display-4">@Model.Titre</h1>
            <p class="badge bg-secondary">@Model.Categorie</p>
            <h2 class="text-primary my-4">@Model.Prix.ToString("C2")</h2>
            
            <hr />
            
            <h5>Description</h5>
            <p class="lead">@Model.Description</p>

            <div class="mt-5">
                <form asp-controller="Panier" asp-action="Ajouter" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="input-group mb-3" style="max-width: 200px;">
                        <span class="input-group-text">Quantité</span>
                        <input type="number" name="quantite" class="form-control" value="1" min="1">
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-cart-plus"></i> Ajouter au panier
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary mt-3">Retour à la boutique</a>
            </div>
        </div>
    </div>
</div>